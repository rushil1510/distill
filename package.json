{
  "name": "distill-js",
  "version": "0.1.0",
  "description": "Extract functions from large files into clean, single-responsibility modules. Automatically rewires imports across your entire codebase. Built for AI agents and humans alike.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "distill": "./bin/distill.js",
    "distill-mcp": "./bin/mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "refactor",
    "extract",
    "function",
    "module",
    "split",
    "codemod",
    "ast",
    "typescript",
    "ai-agent",
    "code-quality"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "files": [
    "dist/",
    "bin/"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^4.1.2",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "diff": "^8.0.2",
    "micromatch": "^4.0.8",
    "ts-morph": "^25.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
